# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# --- Email settings (required) ---
EMAIL_SENDER=your_email@example.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENTS=you@example.com,partner@example.com
SMTP_SERVER=mail.gmx.net
SMTP_PORT=587

# --- Reference point for distance calculation ---
# Coordinates the distance in each email is measured from (e.g. your workplace).
# Default: Stephansplatz, Vienna city center.
REF_LAT=48.208490
REF_LON=16.372080

# --- Gemini AI scoring (optional) ---
# Get a free API key at https://aistudio.google.com/apikey
# Set ENABLE_AI=0 to run without AI scoring.
ENABLE_AI=1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Base prompt for the AI evaluation (German, since listings are German).
# Customize this to describe what YOU care about in an apartment.
APT_EVAL_BASE_PROMPT="Bewerte die Qualität der Wohnung auf einer Skala von 0 bis 100 und gib eine kurze Begründung für deine Bewertung. Berücksichtige Größe, Zimmeranzahl, Kosten, Stockwerk, Freiflächen und die Distanz zum Referenzpunkt (kleiner ist besser)."

# --- Session cookies (required) ---
# The search results are only visible when logged in, so the bot needs your
# browser session: log in at https://wohnungssuche.wohnberatung-wien.at/ and
# copy the cookies from your browser's developer tools (F12 -> Application/
# Storage -> Cookies). When the session expires, the bot finds 0 apartments
# and logs a warning — just log in again and refresh the values here.
WB_COOKIE_PHPSESSID=
WB_COOKIE_StickySession=
# The consent cookie can often be reused as-is; keep the JSON intact
WB_COOKIE_CC_COOKIE={"level": ["necessary_cookies","analytics_cookies","third_party","youtube","vimeo"]}

# --- Automatic application (optional, OFF by default) ---
# WARNING: when enabled, the bot submits real applications on your
# Wohnberatung Wien account. Requires valid session cookies above.
# Read the README section "Automatic application" before turning this on.
AUTOMATIC_APPLICATION=0
# An apartment must meet ALL of the following to trigger an application:
# Maximum distance to your reference point in meters
AUTO_MAX_DISTANCE_M=3000
# Minimum size in square meters (strictly greater-than)
AUTO_MIN_SIZE_SQM=74
# Minimum floor level
AUTO_MIN_FLOOR_LEVEL=3
# Optional: cancel your existing application for this apartment id before
# applying to a new one (you can only have one active application).
# Leave empty to skip.
CANCEL_APPLICATION_APT_ID=

# --- Runtime settings ---
# File that tracks already-notified apartment IDs
SENT_IDS_FILE=sent_apartments.txt
# Delay between detail page requests (seconds) to be nice to the server
DETAIL_DELAY=0.3
LOG_FILE=logfile.log
LOG_LEVEL=INFO
